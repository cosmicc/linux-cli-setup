#!/usr/bin/env bash
#
# Report the installed linux-cli-setup version from managed local state.

set -euo pipefail

STATE_FILE="/var/lib/linux-cli-setup/install.env"
INSTALLED_VERSION_FILE="/usr/local/share/linux-cli-setup/VERSION"
INSTALL_MARKER_PATHS=(
    "/usr/local/bin/linux-cli-motd"
    "/etc/update-motd.d/99-linux-cli-setup"
    "/etc/update-motd.d/50-linux-cli-setup"
    "/etc/fail2ban/jail.d/linux-cli-setup.conf"
    "/etc/logrotate.d/linux-cli-setup"
    "/etc/sysctl.d/99-linux-cli-setup-hardening.conf"
    "/etc/sysctl.d/99-linux-cli-setup-performance.conf"
)
SCRIPT_VERSION="0.6b"

show_help() {
    cat <<'HELP'
Usage: lcsversion [--help] [--version]

Show the currently installed linux-cli-setup version. If no managed install
state exists, report that linux-cli-setup is not installed.
HELP
}

case "${1:-}" in
    "")
        ;;
    --help)
        show_help
        exit 0
        ;;
    --version)
        printf 'lcsversion %s\n' "$SCRIPT_VERSION"
        exit 0
        ;;
    *)
        printf 'Unknown option: %s\n' "$1" >&2
        exit 2
        ;;
esac

if [[ "$#" -gt 1 ]]; then
    printf 'Unexpected extra arguments.\n' >&2
    exit 2
fi

installed=0
if [[ -f "$STATE_FILE" || -f "$INSTALLED_VERSION_FILE" ]]; then
    installed=1
else
    for marker_path in "${INSTALL_MARKER_PATHS[@]}"; do
        if [[ -e "$marker_path" || -L "$marker_path" ]]; then
            installed=1
            break
        fi
    done
fi

if [[ "$installed" -eq 0 ]]; then
    printf 'linux-cli-setup is not installed.\n'
    exit 0
fi

if [[ -r "$STATE_FILE" ]]; then
    version="$(awk -F= '$1 == "version" { print substr($0, index($0, "=") + 1); exit }' "$STATE_FILE")"
elif [[ -r "$INSTALLED_VERSION_FILE" ]]; then
    version="$(tr -d '[:space:]' < "$INSTALLED_VERSION_FILE")"
else
    version=""
fi

printf 'linux-cli-setup %s\n' "${version:-unknown (legacy install)}"
