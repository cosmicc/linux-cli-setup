#!/usr/bin/env bash
#
# NetworkManager dispatcher hook for chrony DHCP NTP sources.

set -euo pipefail

interface="${1:-}"
action="${2:-}"

if [[ -z "$interface" ]]; then
    exit 0
fi

case "$action" in
    up|dhcp4-change|dhcp6-change|connectivity-change)
        ;;
    down|pre-down|vpn-down)
        /usr/local/sbin/linux-cli-chrony-dhcp-source "$interface"
        exit 0
        ;;
    *)
        exit 0
        ;;
esac

servers=()
if [[ -n "${DHCP4_NTP_SERVERS:-}" ]]; then
    read -r -a dhcp4_servers <<< "$DHCP4_NTP_SERVERS"
    servers+=("${dhcp4_servers[@]}")
fi

if [[ -n "${DHCP6_NTP_SERVERS:-}" ]]; then
    read -r -a dhcp6_servers <<< "$DHCP6_NTP_SERVERS"
    servers+=("${dhcp6_servers[@]}")
fi

/usr/local/sbin/linux-cli-chrony-dhcp-source "$interface" "${servers[@]}"
