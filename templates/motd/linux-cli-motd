#!/usr/bin/env bash
#
# Dynamic login MOTD installed by linux-cli-setup. It prefers UniFetch when
# available so login output can show OS-matched ASCII art and a richer host
# summary. If UniFetch is missing or fails, this script falls back to a compact
# built-in status block.

set -euo pipefail

UNIFETCH_CONFIG="/usr/local/share/linux-cli-setup/unifetch-motd.conf"
PUBLIC_IP_URL="https://api.ipify.org"
PUBLIC_IP_TIMEOUT=2

run_unifetch_motd() {
    command -v unifetch >/dev/null 2>&1 || return 1
    [[ -r "$UNIFETCH_CONFIG" ]] || return 1

    unifetch \
        --config "$UNIFETCH_CONFIG" \
        --ascii_distro auto \
        --ip_host "$PUBLIC_IP_URL" \
        --ip_timeout "$PUBLIC_IP_TIMEOUT"
}

separator() {
    printf '%*s\n' 78 '' | tr ' ' '='
}

section_separator() {
    printf '%*s\n' 78 '' | tr ' ' '-'
}

format_bytes_gib() {
    local kib="$1"
    awk -v kib="$kib" 'BEGIN { printf "%.1fGi", kib / 1024 / 1024 }'
}

memory_summary() {
    local total available used
    total="$(awk '/^MemTotal:/ { print $2 }' /proc/meminfo)"
    available="$(awk '/^MemAvailable:/ { print $2 }' /proc/meminfo)"
    used=$((total - available))
    printf '%s / %s' "$(format_bytes_gib "$used")" "$(format_bytes_gib "$total")"
}

root_disk_summary() {
    df -h / | awk 'NR == 2 { printf "%s used of %s (%s)", $3, $2, $5 }'
}

ip_summary() {
    local addresses
    addresses="$(
        ip -o -4 addr show scope global 2>/dev/null |
            awk '{ split($4, ip, "/"); output = output ? output ", " ip[1] : ip[1] } END { print output }'
    )"
    printf '%s' "${addresses:-unavailable}"
}

public_ip_summary() {
    local address=""

    if command -v curl >/dev/null 2>&1; then
        address="$(curl -fsSL --max-time "$PUBLIC_IP_TIMEOUT" "$PUBLIC_IP_URL" 2>/dev/null || true)"
    elif command -v wget >/dev/null 2>&1; then
        address="$(wget -qO- -T "$PUBLIC_IP_TIMEOUT" "$PUBLIC_IP_URL" 2>/dev/null || true)"
    fi

    address="${address//$'\r'/}"
    address="${address//$'\n'/}"
    if [[ "$address" =~ ^[0-9A-Fa-f:.]+$ ]]; then
        printf '%s' "$address"
        return
    fi

    printf 'unavailable'
}

reboot_required() {
    local latest_kernel

    if [[ -f /var/run/reboot-required ]]; then
        printf 'yes'
        return
    fi

    latest_kernel="$(find /usr/lib/modules -mindepth 1 -maxdepth 1 -printf '%f\n' 2>/dev/null | sort -V | tail -n 1 || true)"
    if [[ -n "$latest_kernel" && "$(uname -r)" != "$latest_kernel" ]]; then
        printf 'maybe'
        return
    fi

    printf 'no'
}

service_status() {
    local unit="$1"
    local current_status

    if command -v systemctl >/dev/null 2>&1; then
        current_status="$(systemctl is-active "$unit" 2>/dev/null || true)"
        printf '%s' "${current_status:-unknown}"
        return
    fi

    printf 'unknown'
}

ssh_status() {
    local status
    status="$(service_status ssh.service)"
    if [[ "$status" == "unknown" || "$status" == "inactive" || "$status" == "failed" ]]; then
        status="$(service_status sshd.service)"
    fi
    printf '%s' "$status"
}

if run_unifetch_motd; then
    exit 0
fi

host_name="$(hostname 2>/dev/null || printf 'linux-host')"
load_average="$(cut -d' ' -f1-3 /proc/loadavg)"

separator
printf '  %s\n' "$host_name"
separator
printf '  %-13s %s\n' 'Uptime:' "$(uptime -p | sed 's/^up //')"
printf '  %-13s %s\n' 'Kernel:' "$(uname -r)"
printf '  %-13s %s\n' 'Load Avg:' "$load_average"
printf '  %-13s %s\n' 'Memory:' "$(memory_summary)"
printf '  %-13s %s\n' 'Root Disk:' "$(root_disk_summary)"
printf '  %-13s %s\n' 'Local IP:' "$(ip_summary)"
printf '  %-13s %s\n' 'Public IP:' "$(public_ip_summary)"
section_separator
printf '  ssh: %s\n' "$(ssh_status)"
section_separator
printf '  %-17s %s\n' 'Reboot Required:' "$(reboot_required)"
separator
