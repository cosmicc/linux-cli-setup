#!/usr/bin/env bash
#
# Dynamic login MOTD installed by linux-cli-setup. It prefers UniFetch when
# available so login output can show OS-matched ASCII art and a richer host
# summary. If UniFetch is missing or fails, this script falls back to a compact
# built-in status block.

set -euo pipefail

UNIFETCH_CONFIG="/usr/local/share/linux-cli-setup/unifetch-motd.conf"
PUBLIC_IP_URL="https://api.ipify.org"
PUBLIC_IP_TIMEOUT=1
MOTD_COMMAND_TIMEOUT=2
MOTD_STORAGE_TIMEOUT=1
UNIFETCH_TIMEOUT=4
STATUS_LABEL_WIDTH=22

mounted_storage_paths() {
    local device_id filesystem_type local_source mountpoint raw_mountpoint source storage_key
    local -A seen_storage=()

    command -v findmnt >/dev/null 2>&1 || {
        printf '/\n'
        return
    }

    while IFS= read -r raw_mountpoint; do
        printf -v mountpoint '%b' "$raw_mountpoint"
        [[ -n "$mountpoint" ]] || continue
        [[ "$mountpoint" == /snap* ]] && continue

        filesystem_type=""
        device_id=""
        source=""
        read -r filesystem_type device_id source < <(
            findmnt -n -o FSTYPE,MAJ:MIN,SOURCE --target "$mountpoint" 2>/dev/null || true
        ) || continue

        if [[ "$mountpoint" == "/" ]]; then
            storage_key="root"
            if [[ "$source" == /dev/* ]]; then
                local_source="${source%%\[*}"
                seen_storage["local:${local_source:-${device_id:-$source}}"]="1"
            fi
        elif [[ "$filesystem_type" == "nfs" || "$filesystem_type" == "nfs4" ]]; then
            storage_key="nfs:${source}:${mountpoint}"
        elif [[ "$source" == /dev/* ]]; then
            local_source="${source%%\[*}"
            storage_key="local:${local_source:-${device_id:-$source}}"
        elif [[ "$filesystem_type" == "zfs" ]]; then
            storage_key="local-zfs:$source"
        else
            continue
        fi

        [[ -z "${seen_storage[$storage_key]:-}" ]] || continue
        seen_storage[$storage_key]=1
        printf '%s\n' "$mountpoint"
    done < <(findmnt -ln -o TARGET | LC_ALL=C sort)

    return 0
}

run_unifetch_motd() {
    local output storage_paths

    command -v unifetch >/dev/null 2>&1 || return 1
    [[ -r "$UNIFETCH_CONFIG" ]] || return 1

    storage_paths="$(mounted_storage_paths)"
    export LINUX_CLI_MOTD_STORAGE_PATHS="${storage_paths:-/}"

    if ! output="$(
        timeout "$UNIFETCH_TIMEOUT" unifetch \
            --config "$UNIFETCH_CONFIG" \
            --ascii_distro auto \
            --ip_host "$PUBLIC_IP_URL" \
            --ip_timeout "$PUBLIC_IP_TIMEOUT" 2>/dev/null
    )"; then
        return 1
    fi

    printf '%s\n' "$output"

    # Older installations may still have a pre-0.6b UniFetch configuration, so
    # add the current status block when that configuration lacks newer fields.
    if ! grep -Fq 'LINUX_CLI_MOTD_STORAGE_PATHS' "$UNIFETCH_CONFIG" || \
        ! grep -Fq 'info "Updates" package_updates' "$UNIFETCH_CONFIG" || \
        ! grep -Fq 'info "DNS Servers" dns_servers' "$UNIFETCH_CONFIG"; then
        extended_status_block
    fi
}

separator() {
    printf '%*s\n' 78 '' | tr ' ' '='
}

section_separator() {
    printf '%*s\n' 78 '' | tr ' ' '-'
}

section_heading() {
    printf '  %s\n' "$1"
}

status_line() {
    local label="$1"
    local value="$2"

    printf '  %-*s %s\n' "$STATUS_LABEL_WIDTH" "$label" "$value"
}

format_bytes_gib() {
    local kib="$1"
    awk -v kib="$kib" 'BEGIN { printf "%.1fGi", kib / 1024 / 1024 }'
}

memory_summary() {
    local total available used used_percent
    total="$(awk '/^MemTotal:/ { print $2 }' /proc/meminfo)"
    available="$(awk '/^MemAvailable:/ { print $2 }' /proc/meminfo)"
    used=$((total - available))
    used_percent="$(awk -v used="$used" -v total="$total" 'BEGIN { printf "%.0f", (total > 0 ? used * 100 / total : 0) }')"
    printf '%s / %s (%s%%)' "$(format_bytes_gib "$used")" "$(format_bytes_gib "$total")" "$used_percent"
}

swap_summary() {
    local free total used used_percent

    total="$(awk '/^SwapTotal:/ { print $2 }' /proc/meminfo)"
    free="$(awk '/^SwapFree:/ { print $2 }' /proc/meminfo)"
    total="${total:-0}"
    free="${free:-0}"
    used=$((total - free))
    used_percent="$(awk -v used="$used" -v total="$total" 'BEGIN { printf "%.0f", (total > 0 ? used * 100 / total : 0) }')"
    printf '%s / %s (%s%%)' "$(format_bytes_gib "$used")" "$(format_bytes_gib "$total")" "$used_percent"
}

process_count_summary() {
    local -a process_directories=(/proc/[0-9]*)

    printf '%s' "${#process_directories[@]}"
}

logged_in_user_count_summary() {
    local count

    count="$(who 2>/dev/null | awk '{ print $1 }' | LC_ALL=C sort -u | grep -c . || true)"
    printf '%s' "${count:-0}"
}

temperature_summary() {
    local temperature_file temperature_value
    local highest_millicelsius=0

    for temperature_file in /sys/class/thermal/thermal_zone*/temp /sys/class/hwmon/hwmon*/temp*_input; do
        [[ -r "$temperature_file" ]] || continue
        temperature_value="$(head -n 1 "$temperature_file" 2>/dev/null || true)"
        [[ "$temperature_value" =~ ^[0-9]+$ ]] || continue
        temperature_value=$((10#$temperature_value))
        if ((temperature_value >= 1000 && temperature_value <= 200000 && temperature_value > highest_millicelsius)); then
            highest_millicelsius="$temperature_value"
        elif ((temperature_value > 0 && temperature_value < 1000 && temperature_value * 1000 > highest_millicelsius)); then
            highest_millicelsius=$((temperature_value * 1000))
        fi
    done

    if ((highest_millicelsius > 0)); then
        awk -v temperature="$highest_millicelsius" 'BEGIN { printf "%.1f C", temperature / 1000 }'
        return
    fi

    if command -v sensors >/dev/null 2>&1; then
        temperature_value="$(
            timeout "$MOTD_COMMAND_TIMEOUT" sensors 2>/dev/null |
                awk '
                    /Package id 0:|Tctl:|CPU Temperature:/ {
                        if (match($0, /[+][0-9]+([.][0-9]+)?/)) {
                            print substr($0, RSTART + 1, RLENGTH - 1)
                            exit
                        }
                    }
                ' || true
        )"
        if [[ "$temperature_value" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
            printf '%s C' "$temperature_value"
        fi
    fi
}

dns_server_summary() {
    local servers

    servers="$({
        awk '$1 == "nameserver" { print $2 }' /etc/resolv.conf 2>/dev/null || true
        if command -v resolvectl >/dev/null 2>&1; then
            timeout "$MOTD_COMMAND_TIMEOUT" resolvectl dns 2>/dev/null |
                awk -F': ' 'NF == 2 { count = split($2, values, " "); for (i = 1; i <= count; i++) print values[i] }' || true
        fi
    } | awk '
        /^[0-9A-Fa-f:.]+$/ && !seen[$0]++ {
            output = output ? output ", " $0 : $0
        }
        END { print output }
    ')"

    printf '%s' "${servers:-unavailable}"
}

os_summary() {
    local pretty_name

    pretty_name="$(sed -n 's/^PRETTY_NAME=//p' /etc/os-release 2>/dev/null | head -n 1)"
    pretty_name="${pretty_name#\"}"
    pretty_name="${pretty_name%\"}"
    printf '%s' "${pretty_name:-Linux}"
}

storage_summary() {
    local -a storage_paths=()
    local disk_output mountpoint percent remaining total used

    mapfile -t storage_paths < <(mounted_storage_paths)
    ((${#storage_paths[@]} > 0)) || storage_paths=(/)

    disk_output="$(
        timeout "$MOTD_STORAGE_TIMEOUT" \
            df -h --output=size,used,avail,pcent,target "${storage_paths[@]}" 2>/dev/null || true
    )"

    while read -r total used remaining percent mountpoint; do
        [[ "$total" == "Size" || -z "$mountpoint" ]] && continue
        status_line "Disk ($mountpoint):" "$used used of $total ($percent), $remaining free"
    done <<< "$disk_output"
}

package_update_summary() {
    local count output status=0

    if command -v pacman >/dev/null 2>&1; then
        output="$(timeout "$MOTD_COMMAND_TIMEOUT" pacman -Qu 2>/dev/null)" || status=$?
        [[ "$status" -eq 1 && -z "$output" ]] && status=0
    elif command -v apt-get >/dev/null 2>&1; then
        output="$(
            timeout "$MOTD_COMMAND_TIMEOUT" \
                apt-get --simulate -o Debug::NoLocking=1 upgrade 2>/dev/null
        )" || status=$?
        if [[ "$status" -eq 0 ]]; then
            output="$(grep '^Inst ' <<< "$output" || true)"
        fi
    else
        printf 'unavailable'
        return
    fi

    if [[ "$status" -eq 124 ]]; then
        printf 'check timed out'
        return
    elif [[ "$status" -ne 0 ]]; then
        printf 'check unavailable'
        return
    fi

    count="$(grep -cve '^[[:space:]]*$' <<< "$output" || true)"
    if [[ "$count" -eq 0 ]]; then
        printf 'none known (cached metadata)'
    else
        printf '%s available (cached metadata)' "$count"
    fi
}

firewall_summary() {
    local enabled status

    if [[ -r /etc/ufw/ufw.conf ]]; then
        enabled="$(awk -F= '/^ENABLED=/ { print tolower($2); exit }' /etc/ufw/ufw.conf)"
        [[ "$enabled" == "yes" ]] && printf 'enabled' || printf 'disabled'
        return
    fi

    if [[ "$EUID" -eq 0 ]] && command -v ufw >/dev/null 2>&1; then
        status="$(timeout 1 ufw status 2>/dev/null | awk 'NR == 1 { print tolower($2) }')"
        printf '%s' "${status:-unavailable}"
        return
    fi

    printf 'unavailable'
}

extended_status_block() {
    local public_ip temperature

    printf '\n'
    separator
    printf '  linux-cli-setup status\n'
    separator
    section_heading 'System'
    status_line 'OS:' "$(os_summary)"
    status_line 'Kernel:' "$(uname -r)"
    status_line 'Uptime:' "$(uptime -p | sed 's/^up //')"
    status_line 'Load Avg:' "$(cut -d' ' -f1-3 /proc/loadavg)"
    temperature="$(temperature_summary)"
    [[ -n "$temperature" ]] && status_line 'Temperature:' "$temperature"
    status_line 'Processes:' "$(process_count_summary)"
    status_line 'Users Logged In:' "$(logged_in_user_count_summary)"
    section_separator
    section_heading 'Resources'
    status_line 'Memory:' "$(memory_summary)"
    status_line 'Swap:' "$(swap_summary)"
    storage_summary
    section_separator
    section_heading 'Network'
    status_line 'Local IP:' "$(ip_summary)"
    status_line 'DNS Servers:' "$(dns_server_summary)"
    public_ip="$(public_ip_summary)"
    if [[ "$public_ip" == "unavailable" ]]; then
        status_line 'Internet:' 'unavailable'
    else
        status_line 'Internet:' "online ($public_ip)"
    fi
    section_separator
    section_heading 'Services'
    status_line 'Updates:' "$(package_update_summary)"
    status_line 'Firewall:' "$(firewall_summary)"
    status_line 'SSH:' "$(ssh_status)"
    status_line 'Reboot Required:' "$(reboot_required)"
    separator
}

ip_summary() {
    local addresses
    addresses="$(
        ip -o -4 addr show scope global 2>/dev/null |
            awk '{ split($4, ip, "/"); output = output ? output ", " ip[1] : ip[1] } END { print output }'
    )"
    printf '%s' "${addresses:-unavailable}"
}

public_ip_summary() {
    local address=""

    if command -v curl >/dev/null 2>&1; then
        address="$(curl -fsSL --max-time "$PUBLIC_IP_TIMEOUT" "$PUBLIC_IP_URL" 2>/dev/null || true)"
    elif command -v wget >/dev/null 2>&1; then
        address="$(wget -qO- -T "$PUBLIC_IP_TIMEOUT" "$PUBLIC_IP_URL" 2>/dev/null || true)"
    fi

    address="${address//$'\r'/}"
    address="${address//$'\n'/}"
    if [[ "$address" =~ ^[0-9A-Fa-f:.]+$ ]]; then
        printf '%s' "$address"
        return
    fi

    printf 'unavailable'
}

reboot_required() {
    local latest_kernel

    if [[ -f /var/run/reboot-required ]]; then
        printf 'yes'
        return
    fi

    latest_kernel="$(find /usr/lib/modules -mindepth 1 -maxdepth 1 -printf '%f\n' 2>/dev/null | sort -V | tail -n 1 || true)"
    if [[ -n "$latest_kernel" && "$(uname -r)" != "$latest_kernel" ]]; then
        printf 'maybe'
        return
    fi

    printf 'no'
}

service_status() {
    local unit="$1"
    local current_status

    if command -v systemctl >/dev/null 2>&1; then
        current_status="$(timeout 1 systemctl is-active "$unit" 2>/dev/null || true)"
        printf '%s' "${current_status:-unknown}"
        return
    fi

    printf 'unknown'
}

ssh_status() {
    local status
    status="$(service_status ssh.service)"
    if [[ "$status" == "unknown" || "$status" == "inactive" || "$status" == "failed" ]]; then
        status="$(service_status sshd.service)"
    fi
    printf '%s' "$status"
}

if run_unifetch_motd; then
    exit 0
fi

host_name="$(hostname 2>/dev/null || printf 'linux-host')"
load_average="$(cut -d' ' -f1-3 /proc/loadavg)"
temperature="$(temperature_summary)"

separator
printf '  %s\n' "$host_name"
separator
section_heading 'System'
status_line 'Uptime:' "$(uptime -p | sed 's/^up //')"
status_line 'OS:' "$(os_summary)"
status_line 'Kernel:' "$(uname -r)"
status_line 'Load Avg:' "$load_average"
[[ -n "$temperature" ]] && status_line 'Temperature:' "$temperature"
status_line 'Processes:' "$(process_count_summary)"
status_line 'Users Logged In:' "$(logged_in_user_count_summary)"
section_separator
section_heading 'Resources'
status_line 'Memory:' "$(memory_summary)"
status_line 'Swap:' "$(swap_summary)"
storage_summary
section_separator
section_heading 'Network'
status_line 'Local IP:' "$(ip_summary)"
status_line 'DNS Servers:' "$(dns_server_summary)"
public_ip="$(public_ip_summary)"
if [[ "$public_ip" == "unavailable" ]]; then
    status_line 'Internet:' 'unavailable'
else
    status_line 'Internet:' "online ($public_ip)"
fi
section_separator
section_heading 'Services'
status_line 'SSH:' "$(ssh_status)"
status_line 'UFW:' "$(firewall_summary)"
status_line 'Updates:' "$(package_update_summary)"
status_line 'Reboot Required:' "$(reboot_required)"
separator
